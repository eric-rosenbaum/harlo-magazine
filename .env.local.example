# ── Sanity ────────────────────────────────────────────────────────────────
# Create a project at https://sanity.io/manage and copy the Project ID here.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Pin an API version (date). Bump intentionally when adopting new Sanity features.
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Server-side read token (Viewer role) for drafts/preview. Never exposed to client.
SANITY_API_READ_TOKEN=

# Shared secret the Sanity webhook sends to /api/revalidate.
SANITY_REVALIDATE_SECRET=
# Secret that gates the draft-mode preview route.
SANITY_PREVIEW_SECRET=

# ── Newsletter (Kit / ConvertKit by default) ───────────────────────────────
NEWSLETTER_PROVIDER_API_KEY=
NEWSLETTER_FORM_ID=

# ── Site ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://harlomagazine.com

# ── Analytics (Plausible) ──────────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Fonts (optional) ───────────────────────────────────────────────────────
# Adobe Fonts (Typekit) kit id for Minion Pro. Leave blank to use the fallback serif.
NEXT_PUBLIC_ADOBE_FONTS_KIT_ID=
